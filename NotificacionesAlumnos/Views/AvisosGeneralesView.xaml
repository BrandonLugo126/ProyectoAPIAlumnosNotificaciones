<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NotificacionesAlumnos.Views.AvisosGeneralesView"
             Title="AvisosGeneralesView" >
    <CollectionView ItemsSource="{Binding AvisosGenerales}" Margin="15">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Border StrokeShape="RoundRectangle 10" 
                        Margin="0,0,0,12" 
                        Padding="0" 
                        StrokeThickness="0"
                        BackgroundColor="White">
                    <VerticalStackLayout>
                        <BoxView Color="#D32F2F" HeightRequest="4"/>

                        <VerticalStackLayout Padding="15" Spacing="5">
                            <Label Text="{Binding Titulo}" FontSize="18" FontAttributes="Bold" TextColor="#D32F2F"/>
                            <Label Text="{Binding Contenido}" FontSize="14" TextColor="#333333" MaxLines="3"/>

                            <HorizontalStackLayout Spacing="5" Margin="0,10,0,0">
                                <Label Text="Vence el:" FontSize="11" FontAttributes="Bold" TextColor="#666666"/>
                                <Label Text="{Binding FechaCaducidad}" FontSize="11" TextColor="#D32F2F"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>
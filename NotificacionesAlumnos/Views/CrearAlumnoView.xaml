<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NotificacionesAlumnos.Views.CrearAlumnoView"
             Title="CrearAlumnoView">
    <ScrollView>
        <VerticalStackLayout Padding="25" Spacing="20">

            <VerticalStackLayout Spacing="5">
                <Label Text="Nuevo Estudiante" FontSize="26" FontAttributes="Bold" TextColor="#2E7D32"/>
                <Label Text="Ingresa los datos para dar de alta en el sistema." TextColor="Gray"/>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="5">
                <Label Text="Asignar a Grupo" FontAttributes="Bold" TextColor="#2E7D32" Margin="5,0"/>
                <Border StrokeShape="RoundRectangle 10" StrokeThickness="1" Stroke="#E0E0E0" Padding="10,0">
                    <Picker Title="Selecciona el grupo..." 
                            ItemsSource="{Binding Grupos}" 
                            ItemDisplayBinding="{Binding NombreGrupo}"
                            TextColor="#333333"/>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="5">
                <Label Text="Nombre Completo" FontAttributes="Bold" TextColor="#2E7D32" Margin="5,0"/>
                <Border StrokeShape="RoundRectangle 10" StrokeThickness="1" Stroke="#E0E0E0" Padding="10,0">
                    <Entry Placeholder="Ej. Juan Pérez" Text="{Binding NombreAlumno}"/>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="5">
                <Label Text="Matrícula" FontAttributes="Bold" TextColor="#2E7D32" Margin="5,0"/>
                <Border StrokeShape="RoundRectangle 10" StrokeThickness="1" Stroke="#E0E0E0" Padding="10,0">
                    <Entry Placeholder="ID del alumno" Keyboard="Numeric" Text="{Binding Matricula}"/>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="5">
                <Label Text="Contraseña Inicial" FontAttributes="Bold" TextColor="#2E7D32" Margin="5,0"/>
                <Border StrokeShape="RoundRectangle 10" StrokeThickness="1" Stroke="#E0E0E0" Padding="10,0">
                    <Entry Placeholder="********" IsPassword="True" Text="{Binding Password}"/>
                </Border>
            </VerticalStackLayout>

            <Button Text="REGISTRAR ALUMNO" 
                    BackgroundColor="#2E7D32" 
                    TextColor="White" 
                    FontAttributes="Bold"
                    CornerRadius="10" 
                    HeightRequest="55" 
                    Margin="0,20,0,0"
                    Command="{Binding RegistrarAlumnoCommand}"/>

            <Button Text="CANCELAR" 
                    BackgroundColor="Transparent" 
                    TextColor="Gray" 
                    Command="{Binding VolverCommand}"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
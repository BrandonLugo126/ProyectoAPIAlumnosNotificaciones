<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NotificacionesAlumnos.Views.PerfilAlumnoView"
             Title="PerfilAlumnoView">
    <VerticalStackLayout Padding="30" Spacing="25" VerticalOptions="Center">

        <Border WidthRequest="120" HeightRequest="120"  
                HorizontalOptions="Center" BackgroundColor="#2B5797" StrokeThickness="0">
            <Label Text="A" TextColor="White" VerticalOptions="Center" 
                   HorizontalOptions="Center" FontSize="50" FontAttributes="Bold"/>
        </Border>

        <VerticalStackLayout HorizontalOptions="Center" Spacing="8">
            <Label Text="Nombre del Alumno" FontSize="22" FontAttributes="Bold" HorizontalOptions="Center"/>
            <Label Text="Matrícula: 12345678" TextColor="Gray" HorizontalOptions="Center"/>
            <Label Text="Carrera / Grado" TextColor="#2B5797" FontAttributes="Bold" HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <BoxView HeightRequest="1" Color="#E0E0E0" Margin="0,10"/>

        <Button Text="CERRAR SESIÓN" 
                BackgroundColor="#C62828" 
                TextColor="White" 
                FontAttributes="Bold"
                CornerRadius="12"
                HeightRequest="55"
                Command="{Binding LogoutCommand}"/>

    </VerticalStackLayout>
</ContentPage>
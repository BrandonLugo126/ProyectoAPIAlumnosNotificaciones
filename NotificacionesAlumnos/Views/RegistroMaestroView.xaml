<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NotificacionesAlumnos.Views.RegistroMaestroView"
             Title="RegistroMaestroView">
    <VerticalStackLayout Padding="30" Spacing="15" VerticalOptions="Center">
        <Label Text="Registro de Docente" FontSize="28" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#2E7D32"/>

        <Border StrokeShape="RoundRectangle 10" Padding="10,0">
            <Entry Placeholder="Nombre Completo" Text="{Binding Nombre}"/>
        </Border>

        <Border StrokeShape="RoundRectangle 10" Padding="10,0">
            <Entry Placeholder="Correo Electrónico" Keyboard="Email" Text="{Binding Correo}"/>
        </Border>

        <Border StrokeShape="RoundRectangle 10" Padding="10,0">
            <Entry Placeholder="Contraseña" IsPassword="True" Text="{Binding Password}"/>
        </Border>

        <Button Text="CREAR CUENTA" BackgroundColor="#2E7D32" TextColor="White" CornerRadius="10" HeightRequest="50" Margin="0,20,0,0"/>
    </VerticalStackLayout>
</ContentPage>